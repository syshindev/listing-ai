# Supabase — fill in from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI — Gemini required, Anthropic optional (for Pro tier)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Dev toggles
# Set AI_MOCK=true to skip real AI calls and return a fixed response (UI iteration, E2E tests)
AI_MOCK=false
